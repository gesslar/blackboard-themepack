{
  "name": "blackboard-themepack",
  "displayName": "Blackboard Theme Pack",
  "description": "Classic blackboard aesthetics for night coding - chalk on slate with electric blue accents",
  "version": "2.2.0",
  "publisher": "gesslar",
  "license": "0BSD",
  "engines": {
    "vscode": ">=1.111.0"
  },
  "scripts": {
    "watch": "npx -y @gesslar/sassy build -wo ./dist ./src/*.yaml",
    "build": "npx -y @gesslar/sassy build -o ./dist ./src/*.yaml",
    "lint-blackboard": "npx -y @gesslar/sassy lint ./src/blackboard.sassy.yaml",
    "lint-corporate": "npx -y @gesslar/sassy lint ./src/corporate.sassy.yaml",
    "lint-bubblegum-goth": "npx -y @gesslar/sassy lint ./src/bubblegum-goth.sassy.yaml",
    "package": "node scripts/assure-clean-vsix-directory.mjs && npm run build && npx -y @vscode/vsce package --no-dependencies --skip-license -o vsix/",
    "publish:vsce": "npm run package && npx -y @vscode/vsce publish --packagePath vsix/*.vsix --pat $VSX_MARKETPLACE_ACCESS_TOKEN",
    "publish:ovsx": "npm run package && npx -y ovsx publish --packagePath vsix/*.vsix --pat $OVSX_ACCESS_TOKEN",
    "pr": "gt submit -p --ai",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major",
    "update": "npx -y npm-check-updates -u && npm install"
  },
  "categories": [
    "Themes"
  ],
  "type": "module",
  "contributes": {
    "themes": [
      {
        "label": "Blackboard",
        "description": "Don't use your nails, eek!",
        "id": "blackboard",
        "uiTheme": "vs-dark",
        "path": "dist/blackboard.color-theme.json"
      },
      {
        "label": "Bubblegum Goth",
        "description": "*POP* goes the emo.",
        "id": "bubblegum-goth",
        "uiTheme": "vs-dark",
        "path": "dist/bubblegum-goth.color-theme.json"
      },
      {
        "label": "Corporate",
        "description": "They'll definitely think you're working now.",
        "id": "corporate",
        "uiTheme": "vs-dark",
        "path": "dist/corporate.color-theme.json"
      }
    ]
  },
  "icon": "media/blackboard.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/gesslar/blackboard-theme"
  },
  "keywords": [
    "theme",
    "blackboard",
    "dark",
    "chalk",
    "night",
    "blue",
    "pink",
    "sassy",
    "but",
    "gui"
  ],
  "__metadata": {
    "id": "blackboard-theme"
  },
  "devDependencies": {
    "@gesslar/toolkit": "^5.8.0",
    "@gesslar/toolkit": "^5.8.0",
    "@gesslar/uglier": "^2.4.1",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.6.0",
    "ovsx": "^1.0.2"
  }
}
